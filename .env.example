PORT=3000

# Runtime mode labels. Production fails fast when local/demo-only adapters are configured.
OMNICLAW_ENV=local
OMNICLAW_AUTH_MODE=headers

# SIWS authentication (used when OMNICLAW_AUTH_MODE=signed)
OMNICLAW_SIWS_DOMAIN=localhost:3000
OMNICLAW_SIWS_NONCE_EXPIRY=300

# Rate limiting
OMNICLAW_RATE_LIMIT_WINDOW_MS=60000
OMNICLAW_RATE_LIMIT_MAX_REQUESTS=100

# Use "memory" for local tests and "postgres" to enable the Drizzle/Postgres repository.
OMNICLAW_STORE=memory
DATABASE_URL=postgres://omniclaw:omniclaw@localhost:5432/omniclaw
DATABASE_POOL_SIZE=10
OMNICLAW_POSTGRES_PORT=5432

# Settlement adapter. Only "mock" is implemented today and is blocked in production mode.
OMNICLAW_SETTLEMENT_ADAPTER=mock

# Mock settlement adapter configuration.
SETTLEMENT_ESCROW_ACCOUNT_PREFIX=mock_escrow
SETTLEMENT_LOCK_TX_PREFIX=mock_lock
SETTLEMENT_PAYOUT_TX_PREFIX=mock_payout
SETTLEMENT_REFUND_TX_PREFIX=mock_refund
SETTLEMENT_PROTOCOL_FEE_WALLET=protocol_fee_wallet
SETTLEMENT_RUNTIME_FEE_WALLET=runtime_fee_wallet

# Runtime adapter. Use "mock" for local API tests or "grpc" for the Python runtime.
OMNICLAW_RUNTIME_ADAPTER=mock
OMNICLAW_RUNTIME_GRPC_TARGET=localhost:50051

# Python runtime configuration.
# Use "echo" for local runtime smoke tests or "deepseek" for model-backed execution.
OMNICLAW_RUNTIME_PROVIDER=deepseek
OMNICLAW_RUNTIME_GRAPH=langgraph
OMNICLAW_RUNTIME_SANDBOX=noop
OMNICLAW_RUNTIME_TIMEOUT_SECONDS=60
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
E2B_API_KEY=
E2B_TEMPLATE=
